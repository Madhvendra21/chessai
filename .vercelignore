# Vercel Ignore Rules
# These files/folders are excluded from the build

# Development files
.env
.env.local
.env.*.local
.git
.github
.gitignore

# Documentation
docs/
*.md
!DEPLOY_NOW.md

# Docker files (not needed for Vercel)
docker/

# Scripts (not needed for runtime)
scripts/

# Data files (large, not needed for build)
data/
*.pth
*.onnx
*.weights
models/

# Testing
tests/
test/
.pytest_cache/

# Local development
.DS_Store
.idea/
.vscode/
*.log
local_settings.py

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# Build outputs
dist/
build/
*.egg-info/

# Frontend source (already built or served separately)
# frontend/src/  # Commented out - might be needed

# Allow api/ folder for Vercel functions - DO NOT EXCLUDE
# api/

# Allow backend/ for potential imports if needed
# backend/