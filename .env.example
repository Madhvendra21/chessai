# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/chessvision

# Redis
REDIS_URL=redis://localhost:6379/0

# Storage
UPLOAD_DIR=data/uploads
FRAMES_DIR=data/frames
MODELS_DIR=data/models
MAX_UPLOAD_SIZE=524288000

# Stockfish (auto-detected if not set)
# STOCKFISH_PATH=/usr/local/bin/stockfish
STOCKFISH_DEPTH=18
STOCKFISH_TIME=1.0

# CV Pipeline
FRAME_EXTRACTION_FPS=2
CONFIDENCE_THRESHOLD=0.5
BOARD_DETECTION_THRESHOLD=0.7

# Processing
MAX_WORKERS=4
JOB_TIMEOUT=3600

# API
API_HOST=0.0.0.0
API_PORT=8000